# {{ ansible_managed }}
# Temporary HTTP-only config for ACME certificate bootstrapping.
# Replaced by baudrate.conf.j2 after certbot obtains the certificate.

server {
    listen 80;
    listen [::]:80;
    server_name {{ domain }};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 503 "SSL certificate not yet provisioned.\n";
        add_header Content-Type text/plain always;
    }
}
