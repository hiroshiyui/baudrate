# {{ ansible_managed }}
# Baudrate runtime environment — loaded by systemd EnvironmentFile
DATABASE_URL=ecto://{{ postgres_db_user }}:{{ postgres_db_password }}@localhost/{{ postgres_db_name }}
SECRET_KEY_BASE={{ secret_key_base }}
PHX_HOST={{ domain }}
PHX_SERVER=true
DATABASE_SSL=false
PORT={{ app_port }}
POOL_SIZE={{ pool_size | default(10) }}
{% if installation_key is defined and installation_key %}
INSTALLATION_KEY={{ installation_key }}
{% endif %}
