---
# Copy this file, then encrypt it with SOPS:
#
#   cp secrets.sops.yml.example secrets.sops.yml
#   sops --encrypt --in-place secrets.sops.yml
#
# To edit later:
#
#   sops secrets.sops.yml
#
# SOPS encrypts only the values — keys remain readable in git diffs.
#
postgres_db_password: "CHANGE_ME"
secret_key_base: "CHANGE_ME"
